PORT=4173
HOST=127.0.0.1
PUBLIC_BASE_URL=https://orders.ksiraa.com
ADMIN_PHONE=9999999999
ADMIN_PASSWORD=change-this-password
OWNER_WHATSAPP=919999999999
BACKUP_RETENTION_DAYS=30

# SMS OTP provider endpoint. The app sends { "to": "mobile", "message": "otp text" }.
SMS_PROVIDER_URL=
SMS_PROVIDER_TOKEN=

# WhatsApp Business provider endpoint. The app sends { "to": "91mobile", "message": "text" }.
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Online payment provider endpoint. The app sends order/payment JSON and expects a paymentUrl/url/short_url field.
PAYMENT_PROVIDER_URL=
PAYMENT_PROVIDER_TOKEN=
PAYMENT_RETURN_URL=https://orders.ksiraa.com/
