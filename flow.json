{
  "version": "7.0",
  "data_api_version": "3.0",
  "routing_model": {
    "SELECT": ["QUANTITIES"],
    "QUANTITIES": []
  },
  "screens": [
    {
      "id": "SELECT",
      "title": "Choose products",
      "data": {
        "product_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "__example__": [
            { "id": "ghee-500", "title": "Pure Desi Ghee", "description": "500 g jar · Rs. 699" }
          ]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "What would you like?"
          },
          {
            "type": "Form",
            "name": "select_form",
            "children": [
              {
                "type": "CheckboxGroup",
                "name": "chosen",
                "label": "Tap the products you want",
                "required": true,
                "data-source": "${data.product_options}"
              },
              {
                "type": "Footer",
                "label": "Continue",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "chosen": "${form.chosen}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "QUANTITIES",
      "title": "Set quantities",
      "terminal": true,
      "success": true,
      "data": {
        "row_ids": { "type": "string", "__example__": "ghee-500,butter-250" },
        "label0": { "type": "string", "__example__": "Pure Desi Ghee — Rs. 699" },
        "label1": { "type": "string", "__example__": "" },
        "label2": { "type": "string", "__example__": "" },
        "label3": { "type": "string", "__example__": "" },
        "label4": { "type": "string", "__example__": "" },
        "vis0": { "type": "boolean", "__example__": true },
        "vis1": { "type": "boolean", "__example__": false },
        "vis2": { "type": "boolean", "__example__": false },
        "vis3": { "type": "boolean", "__example__": false },
        "vis4": { "type": "boolean", "__example__": false },
        "opt0": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [ { "id": "1", "title": "1" }, { "id": "2", "title": "2" } ]
        },
        "opt1": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [ { "id": "1", "title": "1" } ]
        },
        "opt2": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [ { "id": "1", "title": "1" } ]
        },
        "opt3": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [ { "id": "1", "title": "1" } ]
        },
        "opt4": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [ { "id": "1", "title": "1" } ]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "How many of each?"
          },
          {
            "type": "Form",
            "name": "qty_form",
            "children": [
              {
                "type": "Dropdown",
                "name": "q0",
                "label": "${data.label0}",
                "data-source": "${data.opt0}",
                "visible": "${data.vis0}",
                "required": false
              },
              {
                "type": "Dropdown",
                "name": "q1",
                "label": "${data.label1}",
                "data-source": "${data.opt1}",
                "visible": "${data.vis1}",
                "required": false
              },
              {
                "type": "Dropdown",
                "name": "q2",
                "label": "${data.label2}",
                "data-source": "${data.opt2}",
                "visible": "${data.vis2}",
                "required": false
              },
              {
                "type": "Dropdown",
                "name": "q3",
                "label": "${data.label3}",
                "data-source": "${data.opt3}",
                "visible": "${data.vis3}",
                "required": false
              },
              {
                "type": "Dropdown",
                "name": "q4",
                "label": "${data.label4}",
                "data-source": "${data.opt4}",
                "visible": "${data.vis4}",
                "required": false
              },
              {
                "type": "Footer",
                "label": "Submit order",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "ids": "${data.row_ids}",
                    "q0": "${form.q0}",
                    "q1": "${form.q1}",
                    "q2": "${form.q2}",
                    "q3": "${form.q3}",
                    "q4": "${form.q4}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
