{
  "version": "7.0",
  "data_api_version": "3.0",
  "routing_model": {
    "ADDRESS": []
  },
  "screens": [
    {
      "id": "ADDRESS",
      "title": "Delivery address",
      "terminal": true,
      "success": true,
      "data": {
        "cart_summary": { "type": "string", "__example__": "🛒 1 × Pure Desi Ghee\n\nTotal: Rs. 699" },
        "def_name": { "type": "string", "__example__": "" },
        "def_house": { "type": "string", "__example__": "" },
        "def_street": { "type": "string", "__example__": "" },
        "def_city": { "type": "string", "__example__": "" },
        "def_pincode": { "type": "string", "__example__": "" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Your order"
          },
          {
            "type": "TextBody",
            "text": "${data.cart_summary}"
          },
          {
            "type": "TextSubheading",
            "text": "Where should we deliver?"
          },
          {
            "type": "Form",
            "name": "address_form",
            "init-values": {
              "name": "${data.def_name}",
              "house": "${data.def_house}",
              "street": "${data.def_street}",
              "city": "${data.def_city}",
              "pincode": "${data.def_pincode}"
            },
            "children": [
              { "type": "TextInput", "name": "name", "label": "Full name", "input-type": "text", "required": true },
              { "type": "TextInput", "name": "house", "label": "House / flat no.", "input-type": "text", "required": true },
              { "type": "TextInput", "name": "street", "label": "Street / area", "input-type": "text", "required": true },
              { "type": "TextInput", "name": "city", "label": "City", "input-type": "text", "required": true },
              { "type": "TextInput", "name": "pincode", "label": "Pincode", "input-type": "text", "required": true },
              {
                "type": "Footer",
                "label": "Place order",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "name": "${form.name}",
                    "house": "${form.house}",
                    "street": "${form.street}",
                    "city": "${form.city}",
                    "pincode": "${form.pincode}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
